# Convex deployment URL (public prod URL, e.g. https://xxxxx.convex.cloud)
CONVEX_URL=

# Shared secret between the WhatsApp bot and this MCP server.
# Every request to /mcp must include: Authorization: Bearer <MCP_CLIENT_SECRET>
MCP_CLIENT_SECRET=

# Port to listen on (default 3000)
PORT=3000

# Allowed origins for CORS (comma-separated). Leave empty to disallow browser callers.
ALLOWED_ORIGINS=
